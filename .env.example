APP_ENV=local
LOG_LEVEL=DEBUG

API_AUTH_TOKEN=change-me
CALLBACK_AUTH_TOKEN=
# Django embeds the webhook secret in callback_url; keep CALLBACK_AUTH_TOKEN empty unless Django accepts Authorization.
DJANGO_CALLBACK_BASE_URL=https://assessment.zecdata.com

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_DEFAULT_QUEUE=assessment
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=1800
CELERY_TASK_TIME_LIMIT_SECONDS=2100
CELERY_TASK_MAX_RETRIES=3





TIME_ZONE=Asia/Kolkata

# Webhook secret
WEBHOOK_SECRET=dummy-webhook-secret-123456789


AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_STORAGE_BUCKET_NAME=ai--assessment
AWS_REGION=ap-south-1
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_SIGNATURE_VERSION=s3v4
USE_S3=True

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Optional. If empty, the worker also checks ../credentials/google-credentials.json.
# Or paste the JSON inline via GOOGLE_CREDENTIALS_JSON (useful for Docker/Render).
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CREDENTIALS_JSON=
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4

CALLBACK_TIMEOUT_SECONDS=10
CALLBACK_MAX_RETRIES=3
